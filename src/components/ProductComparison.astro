---
import AffiliateLink from './AffiliateLink.astro';
export interface Product { name: string; image?: string; price: string; rating?: number; pros: string[]; cons: string[]; verdict?: string; buyLink?: string; buyText?: string; }
export interface Props { products: Product[]; title?: string; }
const { products, title = 'Product Comparison' } = Astro.props;
const maxRating = Math.max(...products.map(p => p.rating || 0));
---

<div class="comparison">
  {title && (
    <div class="comparison-header">
      <h2>{title}</h2>
    </div>
  )}

  <div class="vs-strip">
    {products.slice(0, 3).map((p, i) => (
      <>
        <div class:list={['vs-product', { 'vs-product--winner': p.rating === maxRating }]}>
          <span class="vs-name">{p.name}</span>
          {p.rating && (
            <div class="vs-score">
              <span class="vs-score-value">{p.rating}</span>
              <span class="vs-score-max">/10</span>
            </div>
          )}
          {p.rating === maxRating && <span class="vs-winner-tag">Winner</span>}
        </div>
        {i < Math.min(products.length, 3) - 1 && <span class="vs-divider">vs</span>}
      </>
    ))}
  </div>

  {products[0]?.rating && (
    <div class="score-bars">
      {products.slice(0, 3).map((p) => (
        <div class="score-bar-row">
          <span class="score-bar-label">{p.name}</span>
          <div class="score-bar-track">
            <div
              class:list={['score-bar-fill', { 'score-bar-fill--winner': p.rating === maxRating }]}
              style={`width: ${((p.rating || 0) / 10) * 100}%`}
            ></div>
          </div>
          <span class="score-bar-value">{p.rating}/10</span>
        </div>
      ))}
    </div>
  )}

  <div class="comparison-scroll">
    <table class="comparison-table">
      <thead>
        <tr>
          <th class="feature-col"></th>
          {products.slice(0, 3).map((p) => (
            <th class="product-col">{p.name}</th>
          ))}
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="feature-cell">Price</td>
          {products.slice(0, 3).map((p) => (
            <td class="price-cell">{p.price}</td>
          ))}
        </tr>
        <tr>
          <td class="feature-cell">Strengths</td>
          {products.slice(0, 3).map((p) => (
            <td>
              <ul class="trait-list">
                {p.pros.map((pro) => (
                  <li><span class="trait-icon trait-icon--pro">+</span>{pro}</li>
                ))}
              </ul>
            </td>
          ))}
        </tr>
        <tr>
          <td class="feature-cell">Weaknesses</td>
          {products.slice(0, 3).map((p) => (
            <td>
              <ul class="trait-list">
                {p.cons.map((con) => (
                  <li><span class="trait-icon trait-icon--con">&minus;</span>{con}</li>
                ))}
              </ul>
            </td>
          ))}
        </tr>
        <tr class="action-row">
          <td class="feature-cell"></td>
          {products.slice(0, 3).map((p) => (
            <td>
              {p.buyLink ? (
                <AffiliateLink href={p.buyLink}>{p.buyText || 'Visit'}</AffiliateLink>
              ) : (
                <span class="no-link">Coming soon</span>
              )}
            </td>
          ))}
        </tr>
      </tbody>
    </table>
  </div>
</div>

<style>
  .comparison { margin: var(--space-2xl) 0; }
  .comparison-header h2 { margin-top: 0; margin-bottom: var(--space-lg); }

  .vs-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    background: var(--surface-inverse);
    border-radius: var(--border-radius-lg) var(--border-radius-lg) 0 0;
    padding: var(--space-lg) var(--space-xl);
  }

  .vs-product {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    position: relative;
  }

  .vs-name { font-family: var(--font-body); font-weight: 600; font-size: 0.95rem; color: white; letter-spacing: -0.01em; }
  .vs-score { display: flex; align-items: baseline; gap: 1px; }
  .vs-score-value { font-family: var(--font-display); font-size: 1.75rem; color: white; line-height: 1; letter-spacing: -0.02em; }
  .vs-score-max { font-size: 0.75rem; color: var(--ink-500); }

  .vs-winner-tag {
    font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;
    color: #fbbf24; background: rgba(217, 119, 6, 0.2); padding: 0.15rem 0.5rem; border-radius: 3px;
  }

  .vs-product--winner .vs-score-value { color: #fbbf24; }
  .vs-divider { font-family: var(--font-display); font-size: 1rem; font-style: italic; color: var(--ink-600); padding: 0 var(--space-lg); flex-shrink: 0; }

  .score-bars {
    display: flex; flex-direction: column; gap: 0.625rem;
    padding: var(--space-lg) var(--space-xl);
    background: var(--ink-50); border-left: 1px solid var(--ink-100); border-right: 1px solid var(--ink-100);
  }

  .score-bar-row { display: flex; align-items: center; gap: var(--space-md); }
  .score-bar-label { font-size: 0.8rem; font-weight: 600; color: var(--ink-700); min-width: 100px; text-align: right; }
  .score-bar-track { flex: 1; height: 8px; background: var(--ink-100); border-radius: 4px; overflow: hidden; }
  .score-bar-fill { height: 100%; background: var(--ink-400); border-radius: 4px; transition: width 0.6s var(--ease-out); }
  .score-bar-fill--winner { background: var(--electric); }
  .score-bar-value { font-size: 0.8rem; font-weight: 600; color: var(--ink-600); min-width: 40px; }

  .comparison-scroll {
    overflow-x: auto; border: 1px solid var(--ink-100); border-top: none;
    border-radius: 0 0 var(--border-radius-lg) var(--border-radius-lg); -webkit-overflow-scrolling: touch;
  }

  .comparison-table { width: 100%; border-collapse: collapse; background: var(--surface); margin: 0; }
  .comparison-table thead { background: var(--surface-raised); border-bottom: 2px solid var(--ink-100); }
  .comparison-table th { padding: var(--space-sm) var(--space-lg); text-align: left; font-family: var(--font-body); font-weight: 600; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--ink-500); border: none; }
  .feature-col { width: 110px; }
  .comparison-table td { padding: var(--space-md) var(--space-lg); border-bottom: 1px solid var(--ink-100); vertical-align: top; font-size: 0.9rem; }
  .feature-cell { font-weight: 600; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--ink-500); background: var(--surface-raised); white-space: nowrap; }
  .price-cell { font-weight: 600; color: var(--ink-950); font-size: 1rem; }

  .trait-list { list-style: none; padding: 0; margin: 0; }
  .trait-list li { display: flex; align-items: flex-start; gap: 0.4rem; margin-bottom: 0.4rem; font-size: 0.85rem; line-height: 1.45; color: var(--ink-700); }
  .trait-icon { flex-shrink: 0; width: 16px; height: 16px; display: flex; align-items: center; justify-content: center; border-radius: 50%; font-size: 0.7rem; font-weight: 700; margin-top: 1px; }
  .trait-icon--pro { background: var(--emerald-light); color: var(--emerald); }
  .trait-icon--con { background: var(--coral-light); color: var(--coral); }

  .action-row td { border-bottom: none; padding-top: var(--space-md); padding-bottom: var(--space-lg); }
  .no-link { font-size: 0.85rem; color: var(--ink-400); }
  tbody tr { transition: background-color var(--duration-fast) var(--ease-out); }
  tbody tr:hover { background-color: var(--ink-50); }

  @media (max-width: 640px) {
    .vs-strip { flex-direction: column; gap: var(--space-sm); padding: var(--space-md); }
    .vs-divider { padding: 0; }
    .score-bar-label { min-width: 70px; font-size: 0.75rem; }
    .score-bars { padding: var(--space-md); }
    .comparison-table th, .comparison-table td { padding: var(--space-sm) var(--space-md); }
  }
</style>
