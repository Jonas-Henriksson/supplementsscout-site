---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import siteConfig from '../../site.config';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sortedArticles = allArticles.sort((a, b) => {
  const scoreA = a.data.score || 0;
  const scoreB = b.data.score || 0;
  if (scoreB !== scoreA) return scoreB - scoreA;
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
const latestArticles = [...allArticles]
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 8);

const TOP_PICKS = [
  { name: 'Transparent Labs Whey Isolate', price: '$59', category: 'Protein', slug: 'transparent-labs', tag: "Editor's Pick" },
  { name: 'BulkSupplements Creatine', price: '$22', category: 'Creatine', slug: 'bulk-supplements', tag: 'Best Value' },
  { name: 'Legion Pulse Pre-Workout', price: '$49', category: 'Pre-Workout', slug: 'legion', tag: 'Top Rated' },
  { name: 'Mind Lab Pro', price: '$89', category: 'Nootropics', slug: 'mind-lab-pro', tag: 'Best Nootropic' },
  { name: 'Momentous Magnesium L-Threonate', price: '$54', category: 'Sleep', slug: 'momentous', tag: 'Best Sleep' },
];

const featuredArticle = sortedArticles[0];
const rankedArticles = sortedArticles.slice(1, 7);
const remainingArticles = sortedArticles.slice(7);
const API_URL = 'https://newsletter.supplementsscout.net/subscribe';
const SITE_ID = 'supplementscout';
const fGradient = 'linear-gradient(135deg, #064e3b, #0f172a)';
---

<BaseLayout title={`${siteConfig.siteName} — ${siteConfig.tagline}`}>

  <!-- 3-Column Layout Wrapper -->
  <div class="layout-3col">

    <!-- LEFT COLUMN: Latest Reviews -->
    <aside class="col-left">
      <div class="col-header">
        <span class="col-label">Latest Reviews</span>
        <div class="col-line"></div>
      </div>
      <ul class="latest-list">
        {latestArticles.map((article) => (
          <li class="latest-item">
            <a href={`/${article.slug}`} class="latest-link">
              <div class="latest-meta">
                {article.data.category && (
                  <span class="latest-cat">{article.data.category}</span>
                )}
                <time class="latest-date" datetime={new Date(article.data.date).toISOString()}>
                  {new Date(article.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
              </div>
              <span class="latest-title">{article.data.title}</span>
              {article.data.score && (
                <span class="latest-score">
                  <span class="latest-score-val">{article.data.score.toFixed(1)}</span>
                  <span class="latest-score-sep">/10</span>
                </span>
              )}
            </a>
          </li>
        ))}
      </ul>
      {allArticles.length > 8 && (
        <a href="/reviews" class="see-all-link">All reviews &rarr;</a>
      )}
    </aside>

    <!-- CENTER COLUMN: Featured Hero + Rankings -->
    <main class="col-center">

      <!-- Featured Hero -->
      {featuredArticle && (
        <section class="hero-featured" style={`background: ${fGradient};`}>
          <div class="hf-top">
            <span class="hf-rank">#1</span>
            <div class="hf-badges">
              {featuredArticle.data.category && (
                <span class="hf-cat">{featuredArticle.data.category}</span>
              )}
              {featuredArticle.data.badge && (
                <span class:list={['hf-badge', `hf-badge--${featuredArticle.data.badge}`]}>
                  {featuredArticle.data.badge === 'editors-pick' && '★ '}
                  {featuredArticle.data.badge === 'editors-pick' ? "Editor's Pick" :
                   featuredArticle.data.badge === 'top-rated' ? 'Top Rated' :
                   featuredArticle.data.badge === 'best-value' ? 'Best Value' : 'Tested'}
                </span>
              )}
            </div>
          </div>
          <a href={`/${featuredArticle.slug}`} class="hf-link">
            <h2 class="hf-title">{featuredArticle.data.title}</h2>
            <p class="hf-desc">{featuredArticle.data.description}</p>
            <div class="hf-footer">
              <time class="hf-date" datetime={new Date(featuredArticle.data.date).toISOString()}>
                {new Date(featuredArticle.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              </time>
              {featuredArticle.data.winner && (
                <span class="hf-winner">Winner: <strong>{featuredArticle.data.winner}</strong></span>
              )}
              {featuredArticle.data.score && (
                <span class="hf-score">
                  <span class="hf-score-val">{featuredArticle.data.score.toFixed(1)}</span>
                  <span class="hf-score-max">/10</span>
                </span>
              )}
              <span class="hf-cta">Read review &rarr;</span>
            </div>
          </a>
        </section>
      )}

      <!-- Subscribe Strip -->
      <div class="subscribe-strip">
        <div class="subscribe-text">
          <strong>Evidence-first supplement intel.</strong>
          <span>No bro-science. Just studies and stack reports.</span>
        </div>
        <form class="subscribe-form" id="subscribe-form" data-api={API_URL} data-site={SITE_ID}>
          <input
            type="email"
            class="subscribe-input"
            placeholder="your@email.com"
            aria-label="Email address"
            required
          />
          <button type="submit" class="subscribe-btn">Subscribe</button>
        </form>
        <p class="subscribe-msg" id="subscribe-msg" aria-live="polite"></p>
      </div>

      <!-- Ranked Reviews Grid -->
      {rankedArticles.length > 0 && (
        <section class="rankings">
          <div class="section-header">
            <span class="section-label">Top Rankings</span>
            <div class="section-line"></div>
          </div>
          <div class="rankings-grid">
            {rankedArticles.map((article, i) => (
              <div class="article-animate" style={`animation-delay: ${i * 60}ms`}>
                <ArticleCard
                  title={article.data.title}
                  description={article.data.description}
                  date={article.data.date}
                  author={article.data.author}
                  image={article.data.image}
                  category={article.data.category}
                  slug={article.slug}
                  score={article.data.score}
                  badge={article.data.badge}
                  rank={i + 2}
                />
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- More Reviews -->
      {remainingArticles.length > 0 && (
        <section class="more-reviews">
          <div class="section-header">
            <span class="section-label">More Reviews</span>
            <div class="section-line"></div>
          </div>
          <div class="more-grid">
            {remainingArticles.map((article, i) => (
              <div class="article-animate" style={`animation-delay: ${i * 60}ms`}>
                <ArticleCard
                  title={article.data.title}
                  description={article.data.description}
                  date={article.data.date}
                  author={article.data.author}
                  image={article.data.image}
                  category={article.data.category}
                  slug={article.slug}
                  score={article.data.score}
                  badge={article.data.badge}
                />
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Methodology CTA -->
      <section class="methodology-cta">
        <div class="methodology-inner">
          <span class="methodology-label">Our Promise</span>
          <h2>Every score is earned,<br/><em>never sponsored.</em></h2>
          <p>Every supplement is evaluated against the published literature. Affiliate commissions fund our research but never influence rankings — if it doesn't work, we say so.</p>
          <a href="/disclosure" class="methodology-link">Read our full methodology &rarr;</a>
        </div>
      </section>

    </main>

    <!-- RIGHT COLUMN: Sticky Affiliate Picks -->
    <aside class="col-right">
      <div class="col-header">
        <span class="col-label">Top supplement picks</span>
        <div class="col-line"></div>
      </div>
      <ul class="picks-list">
        {TOP_PICKS.map((pick) => (
          <li class="pick-item">
            <a href={`/go/${pick.slug}`} class="pick-link" target="_blank" rel="noopener sponsored">
              <div class="pick-top">
                <span class="pick-cat">{pick.category}</span>
                <span class="pick-tag">{pick.tag}</span>
              </div>
              <span class="pick-name">{pick.name}</span>
              <div class="pick-bottom">
                <span class="pick-price">{pick.price}</span>
                <span class="pick-cta">Check price &rarr;</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
      <p class="picks-disclosure">
        Affiliate links. We earn a small commission at no extra cost to you. Rankings are never influenced by affiliate status.
      </p>
    </aside>

  </div><!-- end layout-3col -->

</BaseLayout>

<script>
  const form = document.getElementById('subscribe-form') as HTMLFormElement | null;
  const msg = document.getElementById('subscribe-msg');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const emailInput = form.querySelector('input[type="email"]') as HTMLInputElement | null;
      const email = emailInput?.value?.trim();
      if (!email) return;
      const api = form.dataset.api || '';
      const siteId = form.dataset.site || '';
      const btn = form.querySelector('button') as HTMLButtonElement | null;
      if (btn) btn.disabled = true;
      try {
        const res = await fetch(api, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, site_id: siteId }),
        });
        if (msg) {
          msg.textContent = res.ok
            ? 'You\'re in. Expect honest scores in your inbox.'
            : 'Something went wrong. Please try again.';
          msg.className = res.ok ? 'subscribe-msg subscribe-msg--ok' : 'subscribe-msg subscribe-msg--err';
        }
        if (res.ok && emailInput) emailInput.value = '';
      } catch {
        if (msg) {
          msg.textContent = 'Network error. Please try again.';
          msg.className = 'subscribe-msg subscribe-msg--err';
        }
      } finally {
        if (btn) btn.disabled = false;
      }
    });
  }
</script>

<style>
  /* ── Layout ── */
  .layout-3col {
    display: grid;
    grid-template-columns: 220px 1fr 220px;
    grid-template-areas: "left center right";
    gap: var(--space-2xl);
    align-items: start;
    width: 100%;
    margin: 0 auto;
    padding: var(--space-3xl) 0 var(--space-4xl);
  }
  .col-left  { grid-area: left; }
  .col-center { grid-area: center; min-width: 0; }
  .col-right { grid-area: right; position: sticky; top: var(--space-2xl); }

  /* ── Column headers ── */
  .col-header { display: flex; align-items: center; gap: 0.5rem; margin-bottom: var(--space-lg); }
  .col-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink-400); white-space: nowrap; }
  .col-line { flex: 1; height: 1px; background: var(--ink-100); }

  /* ── Left: Latest Reviews ── */
  .latest-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0; }
  .latest-item { border-bottom: 1px solid var(--ink-100); }
  .latest-item:last-child { border-bottom: none; }
  .latest-link {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: var(--space-md) 0;
    text-decoration: none;
    color: var(--ink-900, #0f172a);
    transition: color var(--duration-fast, 120ms) ease;
  }
  .latest-link:hover { color: var(--electric, #475569); }
  .latest-meta { display: flex; align-items: center; justify-content: space-between; gap: 0.25rem; }
  .latest-cat { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--electric, #475569); }
  .latest-date { font-size: 0.65rem; color: var(--ink-400); white-space: nowrap; }
  .latest-title { font-size: 0.82rem; font-weight: 600; line-height: 1.35; color: inherit; }
  .latest-score { display: inline-flex; align-items: baseline; gap: 1px; margin-top: 2px; }
  .latest-score-val { font-family: var(--font-display, sans-serif); font-size: 0.85rem; font-weight: 700; color: var(--electric, #475569); }
  .latest-score-sep { font-size: 0.65rem; color: var(--ink-400); }
  .see-all-link { display: inline-block; margin-top: var(--space-md); font-size: 0.78rem; font-weight: 600; color: var(--electric, #475569); text-decoration: none; border-bottom: 1px solid var(--electric, #475569); padding-bottom: 1px; }
  .see-all-link:hover { opacity: 0.75; }

  /* ── Center: Hero Featured ── */
  .hero-featured {
    border-radius: var(--border-radius-lg, 12px);
    padding: var(--space-xl) var(--space-2xl);
    color: white;
    margin-bottom: var(--space-xl);
    position: relative;
    overflow: hidden;
  }
  .hf-top { display: flex; align-items: center; gap: var(--space-md); margin-bottom: var(--space-md); }
  .hf-rank { font-family: var(--font-display, sans-serif); font-size: 2rem; font-weight: 800; color: rgba(255,255,255,0.25); line-height: 1; }
  .hf-badges { display: flex; align-items: center; gap: 0.5rem; }
  .hf-cat { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.5); }
  .hf-badge { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; padding: 0.15rem 0.5rem; border-radius: 3px; }
  .hf-badge--editors-pick { background: rgba(217,119,6,0.25); color: #fbbf24; }
  .hf-badge--top-rated { background: rgba(239,68,68,0.25); color: #fca5a5; }
  .hf-badge--best-value { background: rgba(5,150,105,0.25); color: #6ee7b7; }
  .hf-badge--tested { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.5); }
  .hf-link { display: block; text-decoration: none; color: white; }
  .hf-link:hover .hf-title { color: rgba(255,255,255,0.85); }
  .hf-title { font-size: clamp(1.35rem, 2.5vw, 1.75rem); font-weight: 700; line-height: 1.2; margin: 0 0 var(--space-sm); color: white; }
  .hf-desc { font-size: 0.9rem; line-height: 1.6; color: rgba(255,255,255,0.65); margin: 0 0 var(--space-lg); max-width: 520px; }
  .hf-footer { display: flex; align-items: center; gap: var(--space-md); flex-wrap: wrap; }
  .hf-date { font-size: 0.78rem; color: rgba(255,255,255,0.4); }
  .hf-winner { font-size: 0.78rem; color: rgba(255,255,255,0.5); }
  .hf-winner strong { color: white; font-weight: 600; }
  .hf-score { display: inline-flex; align-items: baseline; gap: 2px; margin-left: auto; }
  .hf-score-val { font-family: var(--font-display, sans-serif); font-size: 2.5rem; font-weight: 800; line-height: 1; color: white; letter-spacing: -0.03em; }
  .hf-score-max { font-size: 0.9rem; color: rgba(255,255,255,0.4); margin-bottom: 4px; }
  .hf-cta { font-size: 0.82rem; font-weight: 600; color: var(--electric, #475569); background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); padding: 0.3rem 0.75rem; border-radius: 6px; white-space: nowrap; }

  /* ── Subscribe Strip ── */
  .subscribe-strip {
    background: var(--ink-50, #f8fafc);
    border: 1px solid var(--ink-100, #e2e8f0);
    border-left: 3px solid var(--electric, #475569);
    border-radius: var(--border-radius, 8px);
    padding: var(--space-lg) var(--space-xl);
    margin-bottom: var(--space-2xl);
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }
  .subscribe-text { display: flex; flex-direction: column; gap: 2px; min-width: 160px; }
  .subscribe-text strong { font-size: 0.85rem; color: var(--ink-900, #0f172a); }
  .subscribe-text span { font-size: 0.75rem; color: var(--ink-500); }
  .subscribe-form { display: flex; gap: 0.5rem; flex: 1; min-width: 200px; }
  .subscribe-input { flex: 1; padding: 0.45rem 0.75rem; font-size: 0.85rem; border: 1px solid var(--ink-200, #cbd5e1); border-radius: 6px; background: white; color: var(--ink-900, #0f172a); outline: none; }
  .subscribe-input:focus { border-color: var(--electric, #475569); box-shadow: 0 0 0 2px rgba(71,85,105,0.15); }
  .subscribe-btn { padding: 0.45rem 1rem; font-size: 0.82rem; font-weight: 600; background: var(--electric, #475569); color: white; border: none; border-radius: 6px; cursor: pointer; white-space: nowrap; transition: opacity 0.15s; }
  .subscribe-btn:hover { opacity: 0.85; }
  .subscribe-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .subscribe-msg { font-size: 0.75rem; width: 100%; margin: 0; padding: 0; }
  .subscribe-msg--ok { color: #059669; }
  .subscribe-msg--err { color: #dc2626; }

  /* ── Section headers ── */
  .section-header { display: flex; align-items: center; gap: var(--space-md); margin-bottom: var(--space-xl); }
  .section-label { font-family: var(--font-body); font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-400); white-space: nowrap; }
  .section-line { flex: 1; height: 1px; background: var(--ink-100); }

  .rankings { margin-bottom: var(--space-3xl); }
  .rankings-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: var(--space-lg); }
  .article-animate { animation: fadeInUp var(--duration-slow, 400ms) var(--ease-out, ease) both; }

  .more-reviews { margin-bottom: var(--space-3xl); }
  .more-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--space-lg); }

  /* ── Methodology CTA ── */
  .methodology-cta { margin: var(--space-3xl) 0 0; }
  .methodology-inner { padding: var(--space-2xl) 0; border-top: 2px solid var(--ink-950, #020617); }
  .methodology-label { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-400); }
  .methodology-inner h2 { margin-top: var(--space-md); margin-bottom: var(--space-md); font-size: clamp(1.5rem, 2.5vw, 2rem); }
  .methodology-inner h2 em { font-style: italic; color: var(--ink-500); }
  .methodology-inner p { color: var(--ink-500); max-width: 480px; line-height: 1.7; font-size: 0.9rem; }
  .methodology-link { display: inline-block; font-size: 0.88rem; font-weight: 600; color: var(--ink-950, #020617); text-decoration: none; border-bottom: 1.5px solid var(--ink-950, #020617); padding-bottom: 2px; margin-top: var(--space-md); transition: opacity 0.15s; }
  .methodology-link:hover { opacity: 0.65; }

  /* ── Right: Affiliate Picks ── */
  .picks-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0; }
  .pick-item { border-bottom: 1px solid var(--ink-100); }
  .pick-item:last-child { border-bottom: none; }
  .pick-link { display: flex; flex-direction: column; gap: 4px; padding: var(--space-md) 0; text-decoration: none; color: var(--ink-900, #0f172a); transition: color 0.15s; }
  .pick-link:hover { color: var(--electric, #475569); }
  .pick-top { display: flex; align-items: center; justify-content: space-between; gap: 0.25rem; }
  .pick-cat { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-400); }
  .pick-tag { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.1rem 0.4rem; border-radius: 3px; background: rgba(71,85,105,0.1); color: var(--electric, #475569); }
  .pick-name { font-size: 0.82rem; font-weight: 600; line-height: 1.3; color: inherit; }
  .pick-bottom { display: flex; align-items: center; justify-content: space-between; margin-top: 2px; }
  .pick-price { font-size: 0.82rem; font-weight: 700; color: var(--ink-900, #0f172a); }
  .pick-cta { font-size: 0.68rem; font-weight: 600; color: var(--electric, #475569); }
  .picks-disclosure { margin-top: var(--space-lg); font-size: 0.65rem; line-height: 1.5; color: var(--ink-400); }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .layout-3col {
      grid-template-columns: 180px 1fr 180px;
      gap: var(--space-xl);
    }
  }

  @media (max-width: 860px) {
    .layout-3col {
      grid-template-columns: 1fr;
      grid-template-areas:
        "center"
        "left"
        "right";
      gap: var(--space-2xl);
    }
    .col-right { position: static; }
    .picks-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0 var(--space-xl); }
    .pick-item { border-bottom: 1px solid var(--ink-100) !important; }
  }

  @media (max-width: 600px) {
    .layout-3col { padding: var(--space-xl) 0 var(--space-3xl); }
    .hero-featured { padding: var(--space-lg); }
    .hf-score-val { font-size: 2rem; }
    .subscribe-strip { flex-direction: column; align-items: stretch; gap: var(--space-md); }
    .subscribe-form { flex-direction: column; }
    .rankings-grid, .more-grid { grid-template-columns: 1fr; }
    .picks-list { grid-template-columns: 1fr; }
  }
</style>
